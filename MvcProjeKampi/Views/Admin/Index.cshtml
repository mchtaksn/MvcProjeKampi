@using EntityLayer.Conctete
@model List<Category>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Kategori Adı</th>
        <th>Sil</th>
        <th>Güncelle</th>
        <th>Başlıklar</th>
    </tr>
    @foreach (var x in Model)
    {
        <tr>
            <td>@x.CategoryID</td>
            <td>@x.CategoryName</td>
            <td><a href="/Admin/DeleteCategory/@x.CategoryID" class="btn btn-danger">Sil</a></td>
            <td><a href="/Admin/EditCategory/@x.CategoryID"class="btn btn-warning">Güncelle</a></td> 
            <td><a href="#"class="btn btn-primary">Başlıklar</a></td>
        </tr>

    }
</table>
<br />
<a href="/Admin/AddCategory" class="btn btn-info">Yeni Kategori</a>

